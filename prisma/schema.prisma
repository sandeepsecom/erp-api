generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
}

enum ContactType {
  LEAD
  CUSTOMER
  VENDOR
  PARTNER
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum LeadSource {
  WEBSITE
  REFERRAL
  COLD_CALL
  WHATSAPP
  EMAIL
  SOCIAL_MEDIA
  TRADE_SHOW
  EXISTING_CUSTOMER
  OTHER
}

enum ActivityType {
  CALL
  MEETING
  EMAIL
  WHATSAPP
  TASK
  DEADLINE
  NOTE
}

enum ActivityStatus {
  PLANNED
  DONE
  CANCELLED
}

enum QuotationState {
  DRAFT
  SENT
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum OrderState {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ChatterMessageType {
  NOTE
  WHATSAPP
  EMAIL
  SYSTEM
  ACTIVITY
}

enum DocumentType {
  QUOTATION
  SALES_ORDER
  INVOICE
  CREDIT_NOTE
  PURCHASE_ORDER
  SERVICE_TICKET
}

model Company {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  legalName        String?
  gstin            String?
  pan              String?
  phone            String?
  email            String?
  logoUrl          String?
  addressLine1     String?
  city             String?
  state            String?
  pincode          String?
  country          String   @default("India")
  tallyCompanyName String?
  bankName          String?
  bankAccountNumber String?
  bankIfsc          String?
  bankAccountName   String?
  bankBranch        String?
  sendgridApiKey    String?
  emailFromAddress  String?
  emailFromName     String?
  internalEmailCC   String[]
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userCompanies UserCompany[]
  contacts      Contact[]
  leads         Lead[]
  activities    Activity[]
  chatterMsgs   ChatterMessage[]
  quotations    Quotation[]
  salesOrders   SalesOrder[]
  docSequences  DocSequence[]
  products      Product[]
  amcContracts  AmcContract[]

  @@map("companies")
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  phone        String?    @unique
  fullName     String
  passwordHash String
  avatarUrl    String?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  userCompanies     UserCompany[]
  refreshTokens     RefreshToken[]
  auditLogs         AuditLog[]
  assignedLeads     Lead[]          @relation("LeadAssignee")
  activities        Activity[]      @relation("ActivityAssignee")
  createdActivities Activity[]      @relation("ActivityCreator")
  chatterMsgs       ChatterMessage[]
  quotations        Quotation[]     @relation("QuotationSalesperson")
  salesOrders       SalesOrder[]    @relation("OrderSalesperson")

  @@map("users")
}

model UserCompany {
  id          String   @id @default(uuid())
  userId      String
  companyId   String
  role        String   @default("USER")
  permissions Json     @default("[]")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@map("user_companies")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model DocSequence {
  id           String       @id @default(uuid())
  companyId    String
  documentType DocumentType
  prefix       String
  lastNumber   Int          @default(0)
  padding      Int          @default(4)
  fiscalYear   String

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, documentType, fiscalYear])
  @@map("doc_sequences")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  companyId String?
  action    String
  model     String
  recordId  String
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([model, recordId])
  @@index([companyId, createdAt])
  @@map("audit_logs")
}

model Product {
  id             String   @id @default(uuid())
  companyId      String
  sku            String?
  name           String
  description    String?
  uom            String   @default("NOS")
  costPrice      Decimal  @default(0) @db.Decimal(15, 2)
  salePrice      Decimal  @default(0) @db.Decimal(15, 2)
  isStorable     Boolean  @default(true)
  isService      Boolean  @default(false)
  taxRate        Decimal  @default(18) @db.Decimal(5, 2)
  hsnCode        String?
  sacCode           String?
  category          String?
  inputTaxRate      Decimal  @default(18) @db.Decimal(5, 2)
  outputTaxRate     Decimal  @default(18) @db.Decimal(5, 2)
  datasheetUrl      String?
  trackSerial       Boolean  @default(false)
  currentStock      Int      @default(0)
  tallyStockItem String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  company        Company         @relation(fields: [companyId], references: [id])
  quotationLines QuotationLine[]
  orderLines     SalesOrderLine[]
serialNumbers  SerialNumber[]

  @@index([companyId])
  @@map("products")
}

model SerialNumber {
  id          String   @id @default(uuid())
  productId   String
  companyId   String
  serialNo    String
  status      String   @default("IN_STOCK")
  orderId     String?
  contactId   String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id])

  @@unique([companyId, serialNo])
  @@map("serial_numbers")
}

model Contact {
  id              String      @id @default(uuid())
  companyId       String
  type            ContactType @default(LEAD)
  firstName       String
  lastName        String?
  companyName     String?
  jobTitle        String?
  email           String?
  phone           String?
  whatsapp        String?
  gstin           String?
  billingAddress  Json?
  shippingAddress Json?
  notes           String?
  assignedTo      String?
  source          LeadSource?
  tags            String[]    @default([])
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?
  amcContracts  AmcContract[]

  company     Company      @relation(fields: [companyId], references: [id])
  leads       Lead[]
  activities  Activity[]
  quotations  Quotation[]
  salesOrders SalesOrder[]

  @@index([companyId])
  @@index([email])
  @@index([phone])
  @@map("contacts")
}

model Lead {
  id                String     @id @default(uuid())
  companyId         String
  contactId         String?
  title             String
  description       String?
  stage             LeadStage  @default(NEW)
  source            LeadSource @default(OTHER)
  priority          Int        @default(1)
  probability       Int        @default(20)
  expectedValue     Decimal    @default(0) @db.Decimal(15, 2)
  assignedTo        String?
  expectedCloseDate DateTime?
  lostReason        String?
  lostNote          String?
  wonAt             DateTime?
  lostAt            DateTime?
  lastActivityAt    DateTime?
  tags              String[]   @default([])
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?

  company    Company    @relation(fields: [companyId], references: [id])
  contact    Contact?   @relation(fields: [contactId], references: [id])
  assignee   User?      @relation("LeadAssignee", fields: [assignedTo], references: [id])
  activities Activity[]
  quotations Quotation[]

  @@index([companyId])
  @@index([companyId, stage])
  @@index([assignedTo])
  @@map("leads")
}

model Activity {
  id          String         @id @default(uuid())
  companyId   String
  type        ActivityType   @default(TASK)
  status      ActivityStatus @default(PLANNED)
  summary     String
  notes       String?
  dueAt       DateTime?
  doneAt      DateTime?
  assignedTo  String?
  createdBy   String?
  refModel    String?
  refId       String?
  leadId      String?
  contactId   String?
  quotationId String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company   Company    @relation(fields: [companyId], references: [id])
  assignee  User?      @relation("ActivityAssignee", fields: [assignedTo], references: [id])
  creator   User?      @relation("ActivityCreator", fields: [createdBy], references: [id])
  lead      Lead?      @relation(fields: [leadId], references: [id])
  contact   Contact?   @relation(fields: [contactId], references: [id])
  quotation Quotation? @relation(fields: [quotationId], references: [id])

  @@index([companyId])
  @@index([refModel, refId])
  @@index([assignedTo, status])
  @@map("activities")
}

model ChatterMessage {
  id            String             @id @default(uuid())
  companyId     String
  type          ChatterMessageType @default(NOTE)
  refModel      String
  refId         String
  userId        String?
  body          String
  subject       String?
  attachments   Json?
  whatsappMsgId String?
  isInternal    Boolean            @default(false)
  createdAt     DateTime           @default(now())

  company Company @relation(fields: [companyId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@index([refModel, refId])
  @@index([companyId])
  @@map("chatter_messages")
}

model Quotation {
  id             String         @id @default(uuid())
  companyId      String
  name           String
  version        Int            @default(1)
  parentId       String?
  contactId      String
  leadId         String?
  salespersonId  String?
  state          QuotationState @default(DRAFT)
  validityDays   Int            @default(30)
  validUntil     DateTime?
  paymentTerms   String?
  deliveryTerms  String?
  notes          String?
  internalNotes  String?
  currency       String         @default("INR")
  subtotal       Decimal        @default(0) @db.Decimal(15, 2)
  discountAmount Decimal        @default(0) @db.Decimal(15, 2)
  taxAmount      Decimal        @default(0) @db.Decimal(15, 2)
  totalAmount    Decimal        @default(0) @db.Decimal(15, 2)
  totalCost      Decimal        @default(0) @db.Decimal(15, 2)
  marginAmount   Decimal        @default(0) @db.Decimal(15, 2)
  marginPct      Decimal        @default(0) @db.Decimal(7, 2)
  sentAt         DateTime?
  confirmedAt    DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  company     Company         @relation(fields: [companyId], references: [id])
  contact     Contact         @relation(fields: [contactId], references: [id])
  lead        Lead?           @relation(fields: [leadId], references: [id])
  salesperson User?           @relation("QuotationSalesperson", fields: [salespersonId], references: [id])
  parent      Quotation?      @relation("QuotationVersions", fields: [parentId], references: [id])
  revisions   Quotation[]     @relation("QuotationVersions")
  lines       QuotationLine[]
  salesOrders SalesOrder[]
  activities  Activity[]

  @@index([companyId])
  @@index([companyId, state])
  @@index([contactId])
  @@map("quotations")

  quotationType     String    @default("SALES")
  amcContractId     String?
}

model QuotationLine {
  id           String   @id @default(uuid())
  quotationId  String
  productId    String?
  sequence     Int      @default(10)
  description  String
  qty          Decimal  @default(1) @db.Decimal(15, 3)
  uom          String   @default("NOS")
  unitPrice    Decimal  @default(0) @db.Decimal(15, 2)
  costPrice    Decimal  @default(0) @db.Decimal(15, 2)
  discountPct  Decimal  @default(0) @db.Decimal(5, 2)
  taxPct       Decimal  @default(18) @db.Decimal(5, 2)
  subtotal     Decimal  @default(0) @db.Decimal(15, 2)
  taxAmount    Decimal  @default(0) @db.Decimal(15, 2)
  lineTotal    Decimal  @default(0) @db.Decimal(15, 2)
  marginAmount Decimal  @default(0) @db.Decimal(15, 2)
  marginPct    Decimal  @default(0) @db.Decimal(7, 2)
  isSection    Boolean  @default(false)
  notes        String?

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id])

  @@index([quotationId])
  @@map("quotation_lines")
}

model SalesOrder {
  id               String     @id @default(uuid())
  companyId        String
  name             String
  quotationId      String?
  contactId        String
  salespersonId    String?
  state            OrderState @default(CONFIRMED)
  confirmedAt      DateTime   @default(now())
  expectedDelivery DateTime?
  paymentTerms     String?
  notes            String?
  currency         String     @default("INR")
  subtotal         Decimal    @default(0) @db.Decimal(15, 2)
  taxAmount        Decimal    @default(0) @db.Decimal(15, 2)
  totalAmount      Decimal    @default(0) @db.Decimal(15, 2)
  totalCost        Decimal    @default(0) @db.Decimal(15, 2)
  marginAmount     Decimal    @default(0) @db.Decimal(15, 2)
  marginPct        Decimal    @default(0) @db.Decimal(7, 2)
  amountInvoiced   Decimal    @default(0) @db.Decimal(15, 2)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  company     Company          @relation(fields: [companyId], references: [id])
  quotation   Quotation?       @relation(fields: [quotationId], references: [id])
  contact     Contact          @relation(fields: [contactId], references: [id])
  salesperson User?            @relation("OrderSalesperson", fields: [salespersonId], references: [id])
  lines       SalesOrderLine[]

  @@index([companyId])
  @@index([companyId, state])
  @@index([contactId])
  @@map("sales_orders")
}

model SalesOrderLine {
  id              String   @id @default(uuid())
  salesOrderId    String
  productId       String?
  quotationLineId String?
  sequence        Int      @default(10)
  description     String
  qty             Decimal  @default(1) @db.Decimal(15, 3)
  uom             String   @default("NOS")
  unitPrice       Decimal  @default(0) @db.Decimal(15, 2)
  costPrice       Decimal  @default(0) @db.Decimal(15, 2)
  taxPct          Decimal  @default(18) @db.Decimal(5, 2)
  subtotal        Decimal  @default(0) @db.Decimal(15, 2)
  taxAmount       Decimal  @default(0) @db.Decimal(15, 2)
  lineTotal       Decimal  @default(0) @db.Decimal(15, 2)
  qtyDelivered    Decimal  @default(0) @db.Decimal(15, 3)
  qtyInvoiced     Decimal  @default(0) @db.Decimal(15, 3)

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product?   @relation(fields: [productId], references: [id])

  @@index([salesOrderId])
  @@map("sales_order_lines")
}

model AmcContract {
  id                  String    @id @default(uuid())
  companyId           String
  contractNumber      String
  contactId           String
  startDate           DateTime
  endDate             DateTime
  monthlyValue        Decimal   @default(0) @db.Decimal(12, 2)
  annualValue         Decimal   @default(0) @db.Decimal(12, 2)
  sites               String?
  servicesCctv        Boolean   @default(false)
  servicesFire        Boolean   @default(false)
  servicesAlarm       Boolean   @default(false)
  servicesSprinkler   Boolean   @default(false)
  servicesPa          Boolean   @default(false)
  renewalReminderDays Int       @default(30)
  status              String    @default("ACTIVE")
  quotationId         String?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  company   Company   @relation(fields: [companyId], references: [id])
  contact   Contact   @relation(fields: [contactId], references: [id])
reminderLogs AmcReminderLog[]
  @@map("amc_contracts")
}

model AmcReminderLog {
  id           String   @id @default(uuid())
  contractId   String
  daysBeforeExpiry Int
  sentAt       DateTime @default(now())
  sentToEmails String[]
  contract     AmcContract @relation(fields: [contractId], references: [id])

  @@unique([contractId, daysBeforeExpiry])
  @@map("amc_reminder_logs")
}